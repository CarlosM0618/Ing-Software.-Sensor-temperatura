import network
import socket
from machine import Pin
from time import sleep
 
led = Pin(2, Pin.OUT)
led.off()
 
ap = network.WLAN(network.AP_IF)
ap.active(True)
ap.config(essid="ESP32_RCP", password="n1gg3rb4ll5", authmode=3)
 
sleep(2)
print("Red WiFi creada: ESP32_RCP")
print("Conectate y abre: http://192.168.4.1")
 
def web_page():
    html = """<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ESP32 LED</title>
<style>
body{font-family:Arial;text-align:center;margin-top:50px;
     background:#1a1a2e;color:white}
h1{font-size:24px}
.btn{display:inline-block;padding:20px 40px;margin:10px;
     font-size:20px;border:none;border-radius:12px;
     cursor:pointer;color:white}
.on{background:#27ae60}
.off{background:#c0392b}
</style>
</head>
<body>
<h1>ESP32 - Control LED</h1>
<a href="/on"><button class="btn on">ENCENDER</button></a>
<a href="/off"><button class="btn off">APAGAR</button></a>
</body>
</html>"""
    return html
 
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
s.bind(('', 80))
s.listen(5)
print("Servidor listo!")
 
while True:
    conn, addr = s.accept()
    request = conn.recv(1024).decode()
 
    if '/on' in request:
        led.on()
        print("LED encendido")
    elif '/off' in request:
        led.off()
        print("LED apagado")
 
    conn.send('HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n')
    conn.send(web_page())
    conn.close()